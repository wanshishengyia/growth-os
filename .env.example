# SQLite 数据库路径
SQLITE_DB_PATH=data/growth.db

# 小米 MiMo AI API（OpenAI兼容）
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
AI_MODEL=xiaomicoding/mimo-v2.5-pro

# OpenAI（可选，备用）
OPENAI_API_KEY=

# AI 月度预算（美元）
AI_MONTHLY_BUDGET_USD=10

# 飞书 Webhook（消息推送）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_USER_ID=

# API 认证
API_TOKEN=change-me-to-random-string
API_PORT=8000

# 定时任务
SCHEDULER_ENABLED=true
MORNING_TIME=07:30
EVENING_TIME=22:00
